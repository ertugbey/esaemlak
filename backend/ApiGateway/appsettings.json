{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyThatIsAtLeast32CharactersLongForHS256",
    "Issuer": "EmlaktanAuthService",
    "Audience": "EmlaktanApp"
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "Jaeger": {
    "AgentHost": "localhost",
    "AgentPort": "6831"
  },
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false,connectTimeout=5000"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:8080",
      "http://localhost:5000",
      "https://esaemlak.com",
      "https://admin.esaemlak.com"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Metadata": {
          "RateLimitPolicy": "auth"
        }
      },
      "listings-route": {
        "ClusterId": "listings-cluster",
        "Match": {
          "Path": "/api/listings/{**catch-all}"
        }
      },
      "search-route": {
        "ClusterId": "listings-cluster",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      },
      "locations-route": {
        "ClusterId": "listings-cluster",
        "Match": {
          "Path": "/api/locations/{**catch-all}"
        }
      },
      "favorites-route": {
        "ClusterId": "listings-cluster",
        "Match": {
          "Path": "/api/favorites/{**catch-all}"
        }
      },
      "agencies-route": {
        "ClusterId": "listings-cluster",
        "Match": {
          "Path": "/api/agencies/{**catch-all}"
        }
      },
      "payments-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        },
        "Metadata": {
          "RateLimitPolicy": "payment"
        }
      },
      "notifications-api-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/hubs/notifications/{**catch-all}"
        }
      },
      "messaging-route": {
        "ClusterId": "messaging-cluster",
        "Match": {
          "Path": "/hubs/chat/{**catch-all}"
        }
      },
      "messaging-api-route": {
        "ClusterId": "messaging-cluster",
        "Match": {
          "Path": "/api/messages/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://localhost:5001"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "utf-8"
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        },
        "Metadata": {
          "RetryPolicy": "3Retries"
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": "true",
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          },
          "Active": {
            "Enabled": "true",
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        }
      },
      "listings-cluster": {
        "Destinations": {
          "listings-service": {
            "Address": "http://localhost:5002"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "utf-8"
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        },
        "Metadata": {
          "RetryPolicy": "3Retries"
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": "true",
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          },
          "Active": {
            "Enabled": "true",
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        }
      },
      "messaging-cluster": {
        "Destinations": {
          "messaging-service": {
            "Address": "http://localhost:5004"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "utf-8"
        },
        "HttpRequest": {
          "ActivityTimeout": "00:02:00"
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": "true",
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          },
          "Active": {
            "Enabled": "true",
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-service": {
            "Address": "http://localhost:5005"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "utf-8"
        },
        "HttpRequest": {
          "ActivityTimeout": "00:01:00"
        },
        "Metadata": {
          "RetryPolicy": "3Retries"
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": "true",
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          },
          "Active": {
            "Enabled": "true",
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": {
            "Address": "http://localhost:5006"
          }
        },
        "HttpClient": {
          "RequestHeaderEncoding": "utf-8"
        },
        "HttpRequest": {
          "ActivityTimeout": "00:01:00"
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": "true",
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          },
          "Active": {
            "Enabled": "true",
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        }
      }
    }
  }
}